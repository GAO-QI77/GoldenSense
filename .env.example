OPENAI_API_KEY=
APP_ENV=development

# Agent gateway
AGENT_DEFAULT_MODEL=gpt-5.4-mini
AGENT_COMPLEX_MODEL=gpt-5.4
AGENT_PUBLIC_API_KEYS=dev-public-key
AGENT_INTERNAL_API_KEYS=dev-internal-key
AGENT_ALLOW_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://localhost:8501,http://127.0.0.1:8501
AGENT_ANALYZE_RATE_LIMIT_PER_MINUTE=60
AGENT_ANALYZE_RATE_LIMIT_WINDOW_SECONDS=60
AGENT_TOOL_TIMEOUT_SECONDS=35.0
AGENT_TOOL_CONNECT_TIMEOUT_SECONDS=1.5
AGENT_ALLOW_TRACE_MEMORY_FALLBACK=1
AGENT_TRACE_MEMORY_TTL_SECONDS=3600
AGENT_TRACE_MEMORY_MAX_ITEMS=200
VIX_CIRCUIT_BREAKER_THRESHOLD=30
NEWS_STALE_AFTER_SECONDS=300
INFERENCE_MODEL_CHECKPOINTS_DIR_T1=model_checkpoints
INFERENCE_MODEL_CHECKPOINTS_DIR_T7=model_checkpoints

# Internal services
FORECAST_URL=http://localhost:8010/api/v1/forecast
MEMORY_URL=http://localhost:8012/api/v1/memory/search
MARKET_SNAPSHOT_URL=http://localhost:8014/api/v1/market/snapshot/latest
MARKET_INDICATORS_URL=http://localhost:8014/api/v1/market/indicators/current
RECENT_NEWS_URL=http://localhost:8016/api/v1/news/recent

# Storage and providers
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
MARKET_DATA_PROVIDER=yfinance
NEWS_DATA_PROVIDER=rss
INFERENCE_ALLOW_SYNTHETIC_FALLBACK=1
MARKET_ALLOW_SYNTHETIC_FALLBACK=1
NEWS_ALLOW_SAMPLE_FALLBACK=1
MARKET_START_BACKGROUND_TASK=0
NEWS_START_BACKGROUND_TASK=0
NEWS_FETCH_TIMEOUT_SECONDS=4.0
NEWS_STALE_CACHE_GRACE_SECONDS=1800
MEMORY_START_BACKGROUND_LOAD=0
MEMORY_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2

# Frontend
VITE_AGENT_API_URL=http://localhost:8020/api/v1/agent/analyze
VITE_AGENT_DASHBOARD_URL=http://localhost:8020/api/v1/agent/dashboard/current
VITE_AGENT_FEEDBACK_URL=http://localhost:8020/api/v1/agent/feedback
VITE_AGENT_API_KEY=dev-public-key
AGENT_GATEWAY_INTERNAL_API_KEY=dev-internal-key
